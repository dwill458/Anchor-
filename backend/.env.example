# ============================================================================
# Anchor App - Backend Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
# connection_limit: max connections per Prisma instance (default is 5 * CPU cores, often too low)
# pool_timeout: seconds to wait for a free connection before erroring (default 10)
DATABASE_URL="postgresql://user:password@localhost:5432/anchor_db?schema=public&connection_limit=20&pool_timeout=20"
REDIS_URL="redis://localhost:6379"

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------
PORT=3000
NODE_ENV="development"

# ----------------------------------------------------------------------------
# Authentication & Security
# ----------------------------------------------------------------------------
JWT_SECRET="your-secret-key-here-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Set to "true" only if you intentionally want to bypass Firebase auth with
# the mobile mock AuthService during local development. Keep this "false" when
# testing real Firebase sign-in.
ENABLE_MOCK_AUTH="false"

# ----------------------------------------------------------------------------
# Firebase Admin Configuration
# Get these from Firebase Console:
# Project settings -> Service accounts -> Firebase Admin SDK -> Generate new private key
# Download the JSON, then map:
#   FIREBASE_PROJECT_ID  <- project_id
#   FIREBASE_CLIENT_EMAIL <- client_email
#   FIREBASE_PRIVATE_KEY <- private_key
#
# IMPORTANT:
# - Keep the service account JSON on the backend only. Never put it in the mobile app.
# - Replace actual line breaks in private_key with literal \n sequences when pasting into .env.
# ----------------------------------------------------------------------------
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="your-client-email"

# ----------------------------------------------------------------------------
# AI & Image Generation
# ----------------------------------------------------------------------------
# Gemini 3 Pro Image (Primary) - Nano Banana Pro
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# Quality Tier (optional)
# Options: 'premium' (gemini-3-pro-image-preview, highest fidelity, $0.02/image)
#          'draft' (gemini-3-flash-preview, faster/cheaper, $0.005/image)
# Default: 'premium'
GEMINI_TIER="premium"

# Replicate API (Fallback) - Stable Diffusion ControlNet
REPLICATE_API_TOKEN="your-replicate-token"

# AI Provider Selection (optional)
# Options: 'gemini' (primary), 'replicate' (fallback only), 'auto' (default - tries Gemini first)
AI_PROVIDER="auto"

# ----------------------------------------------------------------------------
# Storage (Cloudflare R2 - S3 Compatible)
# ----------------------------------------------------------------------------
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="anchor-assets"
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
R2_PUBLIC_URL="https://your-public-domain.com"

# ----------------------------------------------------------------------------
# E-commerce (Printful)
# ----------------------------------------------------------------------------
PRINTFUL_API_KEY="your-printful-key"
PRINTFUL_WEBHOOK_SECRET="your-webhook-secret"

# ----------------------------------------------------------------------------
# Subscriptions (RevenueCat)
# ----------------------------------------------------------------------------
REVENUECAT_API_KEY="your-revenuecat-key"

# ----------------------------------------------------------------------------
# Google Text-to-Speech
# ----------------------------------------------------------------------------
GOOGLE_TTS_API_KEY="your-google-tts-key"

# ----------------------------------------------------------------------------
# Optional - Analytics & Monitoring
# ----------------------------------------------------------------------------
SENTRY_DSN=""
SEGMENT_WRITE_KEY=""
