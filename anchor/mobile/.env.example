# ============================================================================
# Anchor App - Mobile Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values
# Note: Expo requires public variables to be prefixed with EXPO_PUBLIC_

# ----------------------------------------------------------------------------
# Application Core
# ----------------------------------------------------------------------------

# The target environment (development, staging, production)
EXPO_PUBLIC_APP_ENV=development

# The app release version string, used for error tracking and logging
EXPO_PUBLIC_APP_RELEASE=anchor-v2@1.0.0

# The URL of the backend API
EXPO_PUBLIC_DEV_API_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# Developer Tools & Logging
# ----------------------------------------------------------------------------

# Enables additional developer tools in the UI
EXPO_PUBLIC_DEV_TOOLS=false

# Enables detailed debug logging console output
EXPO_PUBLIC_DEBUG_LOGGING=false

# ----------------------------------------------------------------------------
# Error Tracking & Monitoring (Sentry)
# ----------------------------------------------------------------------------

# Sentry Data Source Name (DSN) for error reporting. Leave empty in dev usually.
EXPO_PUBLIC_SENTRY_DSN=

# Set to true to enable Sentry error tracking in development builds
EXPO_PUBLIC_ENABLE_SENTRY_IN_DEV=false

# The sample rate for performance tracing (0.0 to 1.0)
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.2

# The sample rate for profiling (0.0 to 1.0)
EXPO_PUBLIC_SENTRY_PROFILES_SAMPLE_RATE=0.1

# Threshold in milliseconds to distinguish slow requests in monitoring
EXPO_PUBLIC_SLOW_REQUEST_MS=2000

# ----------------------------------------------------------------------------
# Analytics (PostHog)
# ----------------------------------------------------------------------------

# PostHog project API key (get from posthog.com → Project Settings → API Keys)
EXPO_PUBLIC_POSTHOG_API_KEY=

# PostHog ingestion host. Use the US cloud default or your self-hosted URL.
# US cloud:  https://us.i.posthog.com
# EU cloud:  https://eu.i.posthog.com
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Set to true to enable analytics in dev builds (default: disabled in dev)
EXPO_PUBLIC_ENABLE_ANALYTICS_IN_DEV=false
