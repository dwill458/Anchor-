# ============================================================================
# Anchor App - Mobile Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values
# Note: Expo requires public variables to be prefixed with EXPO_PUBLIC_

# ----------------------------------------------------------------------------
# Application Core
# ----------------------------------------------------------------------------

# The target environment (development, staging, production)
EXPO_PUBLIC_APP_ENV=development

# The app release version string, used for error tracking and logging
EXPO_PUBLIC_APP_RELEASE=anchor-v2@1.0.0

# Override API URL for ALL build types (dev and release APK).
# Use this to point any APK at a local backend exposed via ngrok/tunnel:
#   1. cd backend && npm run dev        (runs at http://localhost:8000)
#   2. ngrok http 8000                  (exposes it as https://xxxx.ngrok.io)
#   3. Set this to the ngrok HTTPS URL and rebuild the APK
# EXPO_PUBLIC_API_URL=https://xxxx.ngrok.io

# Dev-only backend URL (used when __DEV__=true; ignored if EXPO_PUBLIC_API_URL is set).
# For physical device: use your machine's LAN IP (e.g. http://192.168.1.x:8000)
# For Android emulator: use http://10.0.2.2:8000
EXPO_PUBLIC_DEV_API_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# Developer Tools & Logging
# ----------------------------------------------------------------------------

# Enables additional developer tools in the UI
EXPO_PUBLIC_DEV_TOOLS=false

# Enables detailed debug logging console output
EXPO_PUBLIC_DEBUG_LOGGING=false

# ----------------------------------------------------------------------------
# Error Tracking & Monitoring (Sentry)
# ----------------------------------------------------------------------------

# Sentry Data Source Name (DSN) for error reporting. Leave empty in dev usually.
EXPO_PUBLIC_SENTRY_DSN=

# Set to true to enable Sentry error tracking in development builds
EXPO_PUBLIC_ENABLE_SENTRY_IN_DEV=false

# The sample rate for performance tracing (0.0 to 1.0)
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.2

# The sample rate for profiling (0.0 to 1.0)
EXPO_PUBLIC_SENTRY_PROFILES_SAMPLE_RATE=0.1

# Threshold in milliseconds to distinguish slow requests in monitoring
EXPO_PUBLIC_SLOW_REQUEST_MS=2000

# ----------------------------------------------------------------------------
# RevenueCat (In-App Purchases / Subscriptions)
# ----------------------------------------------------------------------------
# Required for subscription management and paywall to function.
# Get these from: https://app.revenuecat.com → Project → API Keys / Entitlements

# Platform-specific public SDK key (use Google Play key for Android, App Store key for iOS)
EXPO_PUBLIC_REVENUECAT_API_KEY=

# The entitlement identifier you defined in the RevenueCat dashboard
# Default is "pro" — change if you named yours differently
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=pro

# The default package to purchase (RevenueCat magic string for monthly)
EXPO_PUBLIC_REVENUECAT_DEFAULT_PACKAGE_ID=$rc_monthly
