{
  "expo": {
    "name": "Anchor",
    "slug": "anchor",
    "version": "1.0.0",
    "newArchEnabled": true,
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "icon": "./assets/anchor-icon.jpg",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/anchor-icon.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A1D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anchor.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Anchor uses your camera to capture moments for your anchors.",
        "NSMicrophoneUsageDescription": "Anchor uses your microphone to record audio mantras.",
        "NSFaceIDUsageDescription": "Anchor uses Face ID to keep your anchors secure.",
        "NSPhotoLibraryUsageDescription": "Anchor accesses your photo library to personalize your anchors.",
        "NSPhotoLibraryAddUsageDescription": "Anchor saves exported anchor wallpapers to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/anchor-icon.jpg",
        "backgroundColor": "#1A1A1D"
      },
      "package": "com.anchor.app",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@sentry/react-native/expo",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "@sentry/react-native",
      "expo-audio",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "8fc5bf55-b18f-41c9-a8ce-767b307debb7"
      }
    },
    "owner": "dwill458"
  }
}
