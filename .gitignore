# ============================================================================
# Anchor App - Git Ignore
# ============================================================================

# ----------------------------------------------------------------------------
# Dependencies
# ----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# ----------------------------------------------------------------------------
# Testing
# ----------------------------------------------------------------------------
coverage/
.nyc_output/

# ----------------------------------------------------------------------------
# Production Builds
# ----------------------------------------------------------------------------
build/
dist/

# ----------------------------------------------------------------------------
# Environment Variables & Secrets
# ----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Firebase / GCP service account keys
*-firebase-adminsdk-*.json
*service-account*.json
*serviceaccount*.json

# Firebase mobile config artifacts (generated or environment-specific)
anchor/mobile/google-services.json
anchor/mobile/android/app/google-services.json
anchor/mobile/ios/GoogleService-Info.plist

# ----------------------------------------------------------------------------
# IDE & Editors
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ----------------------------------------------------------------------------
