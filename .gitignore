frontend/android/gradlew.bat
frontend/android/local.properties
frontend/android/.idea/
frontend/android/build/
frontend/android/app/build/

# ----------------------------------------------------------------------------
# Prisma
# ----------------------------------------------------------------------------
# All migrations are tracked — new migrations are picked up automatically.
# Never add a blanket "migrations/*" exclusion here; every migration SQL file
# must be version-controlled so that deploys and fresh clones are repeatable.

# ----------------------------------------------------------------------------
# Temporary Files
# ----------------------------------------------------------------------------
tmp/
temp/
*.tmp
.cache/

# ----------------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------------
logs
*.log
backend/*_backend_log.txt
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# ----------------------------------------------------------------------------
# Misc
